# Cogento self-hosted – copy to .env and set values before first start
# =============================================================================

# ONBOARDING_BY_INVITE=false (default: self-service). Set true for invite-only.

# --- MUST SET BEFORE FIRST RUN ---
# Pull images from GitHub Container Registry (your GitHub user or org)
GHCR_OWNER=stefano-edgible

# Database password. Change from default; keep secret.
POSTGRES_USER=cogento
POSTGRES_PASSWORD=changeme

# First shared-database admin. Set before first ./start.sh (bootstrap runs only on first Postgres init).
# If you skip it, add a superuser later via ./scripts/db/add_shared_superuser.sh or SQL.
SHARED_SUPERUSER_EMAIL=admin@example.com

# --- REQUIRED FOR LOGIN (login codes/PINs are sent by email; without this, no one can sign in) ---
# Option A: SMTP
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=noreply@cogento.com
# MAIL_FROM_NAME=Cogento

# Option B: Resend (use instead of SMTP)
# RESEND_API_KEY=

# --- OPTIONAL: IMAGE TAG & DATA PATH ---
# Image tag: default "latest" (amd64). On Apple Silicon set COGENTO_IMAGE_TAG=latest-arm64
# COGENTO_IMAGE_TAG=latest

# Where to store data (default: ./volumes). On a server use e.g. /data
# COGENTO_DATA_ROOT=.

# --- OPTIONAL: PGADMIN (only if you use start-with-pgadmin.sh) ---
# PGADMIN_EMAIL=admin@cogento.com
# PGADMIN_PASSWORD=admin
# PGADMIN_PORT=5050

# --- OPTIONAL: PORTS (defaults shown) ---
# POSTGRES_PORT=5432
# API_PORT=8000
# UI_PORT=3000

# --- OPTIONAL: UI BASE URL (for links in emails) ---
# UI_BASE_URL=http://localhost:3000

# --- OPTIONAL: PROGENTO (help chat, docs, technical KB) ---
# PROGENTO_API_URL=http://172.17.0.1:8001
# PROGENTO_COGENTO_KB_REPO_ID=cogento
# PROGENTO_HELP_CHAT_MODEL=phi
# PROGENTO_DOCS_KB_REPO_ID=
# PROGENTO_TECHNICAL_KB_REPO_ID=

# --- OPTIONAL: MULTI-TENANT STRIPE (encrypt tenant Stripe keys in DB) ---
# Required only if tenants will store Stripe keys. Without it, keys use a temp key (lost on restart).
# Must be a stable Fernet key: run ./generate-stripe-encryption-key.sh and add the printed line here.
# STRIPE_KEY_ENCRYPTION_KEY=

# --- OPTIONAL: CLOUDFLARE TURNSTILE ---
# TURNSTILE_SITE_KEY=
# TURNSTILE_SECRET_KEY=
