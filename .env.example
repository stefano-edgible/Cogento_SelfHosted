# Cogento self-hosted – copy to .env and adjust
# Required for pulling images from GitHub Container Registry
GHCR_OWNER=stefano-edgible

# Where to store data (default: ./volumes under this repo)
# On a server with a data disk use e.g. /data
COGENTO_DATA_ROOT=.

# PostgreSQL
POSTGRES_USER=cogento
POSTGRES_PASSWORD=changeme

# Optional: initial superuser in cogento_shared (created by bootstrap script)
# SHARED_SUPERUSER_EMAIL=admin@example.com

# Optional: pgAdmin (only used with --profile with-pgadmin)
# PGADMIN_EMAIL=admin@cogento.com
# PGADMIN_PASSWORD=admin
# PGADMIN_PORT=5050

# Optional: ports (defaults shown)
# POSTGRES_PORT=5432
# API_PORT=8000
# UI_PORT=3000
# NGINX_HTTP_PORT=80

# Optional: UI base URL for emails/links (default http://localhost:3000)
# UI_BASE_URL=http://localhost:3000

# Optional: Progento integration (help chat, docs, technical KB)
# PROGENTO_API_URL=http://172.17.0.1:8001
# PROGENTO_COGENTO_KB_REPO_ID=cogento
# PROGENTO_HELP_CHAT_MODEL=phi
# PROGENTO_DOCS_KB_REPO_ID=
# PROGENTO_TECHNICAL_KB_REPO_ID=

# Optional: mail (SMTP or Resend)
# MAIL_SERVER=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USERNAME=
# MAIL_PASSWORD=
# MAIL_FROM=noreply@cogento.com
# RESEND_API_KEY=

# Optional: Stripe key encryption (multi-tenant). Must be a Fernet key; run ./generate-stripe-encryption-key.sh to generate.
# STRIPE_KEY_ENCRYPTION_KEY=

# Optional: Turnstile (Cloudflare)
# TURNSTILE_SITE_KEY=
# TURNSTILE_SECRET_KEY=
