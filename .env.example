# Cogento self-hosted – copy to .env and set values before first start
# =============================================================================

# ONBOARDING_BY_INVITE=false (default: self-service). Set true for invite-only.

# --- MUST SET BEFORE FIRST RUN ---
# Pull images from GitHub Container Registry (your GitHub user or org)
GHCR_OWNER=stefano-edgible

# Database password. Change from default; keep secret.
POSTGRES_USER=cogento
POSTGRES_PASSWORD=changeme

# First shared-database admin. Set before first ./start.sh (bootstrap runs only on first Postgres init).
# If you skip it, add a superuser later via ./scripts/db/add_shared_superuser.sh or SQL.
SHARED_SUPERUSER_EMAIL=admin@example.com

# --- REQUIRED FOR LOGIN (login codes/PINs are sent by email; without this, no one can sign in) ---
# Option A: SMTP
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=noreply@cogento.com
# MAIL_FROM_NAME=Cogento

# Option B: Resend (use instead of SMTP)
# RESEND_API_KEY=

# --- OPTIONAL: IMAGE TAG & DATA PATH ---
# Image tag: default "latest" (amd64). On Apple Silicon set COGENTO_IMAGE_TAG=latest-arm64
# COGENTO_IMAGE_TAG=latest

# Where to store data (default: ./volumes). On a server use e.g. /data
# COGENTO_DATA_ROOT=.

# --- OPTIONAL: PGADMIN (only if you use start-with-pgadmin.sh) ---
# PGADMIN_EMAIL=admin@cogento.com
# PGADMIN_PASSWORD=admin
# PGADMIN_PORT=5057
# Saved server label in pgAdmin (defaults to PostgreSQL if unset)
# PGADMIN_SERVER_NAME=Edgible

# --- OPTIONAL: PORTS (defaults shown) ---
# POSTGRES_PORT=5437
# API_PORT=8007
# UI_PORT=3007

# --- OPTIONAL: UI BASE URL (for links in emails) ---
# UI_BASE_URL=http://localhost:3007

# --- OPTIONAL: DONATE (header link; API /public/config) ---
# Hide Donate: set DONATE_DISABLED=true (needs API image that includes this env; rebuild from Cogento if missing).
# Or set DONATE_URL= to your Stripe Payment Link. Empty DONATE_URL in Compose also hides the button.
# DONATE_DISABLED=true
# DONATE_URL=

# --- PRODUCTION: change these secrets (API uses defaults if unset) ---
# Session tokens (JWT): use a long random string, e.g. openssl rand -base64 32
# SESSION_SECRET_KEY=change-session-secret-in-production
# Unsubscribe links in emails
# UNSUBSCRIBE_SECRET_KEY=change-this-secret-key-in-production
# CORS: comma-separated origins (e.g. https://cogento.example.com). If unset, API uses UI_BASE_URL.
# CORS_ORIGINS=

# --- OPTIONAL: LICENSE (Togento-issued tokens in Cogento Tenant Details → License) ---
# Cogento verifies JWTs with the PUBLIC key that matches Togento’s signing PRIVATE key.
#
# Where is the Togento “public” key?
# - It is not a separate download from the Togento UI. It is the RSA *public* half of the same pair
#   configured as LICENSE_PRIVATE_KEY in Togento’s .env (see Togento/.env.example).
# - If you generated keys with:
#     openssl genrsa -out license_private.pem 2048
#     openssl rsa -in license_private.pem -pubout -out license_public.pem
#   then paste the full contents of license_public.pem below (or one line with \n between PEM lines).
# - If you only have the private PEM in Togento, derive the public key:
#     openssl rsa -in license_private.pem -pubout -out license_public.pem
#
# LICENSE_PUBLIC_KEY=
# Issuer claim in the JWT (must match LICENSE_ISSUER in Togento). Default:
# LICENSE_ISSUER=togento
#
# Optional: auto trial license for every *new* tenant (Cogento signs trials; unrelated to Togento).
# openssl genrsa -out trial_private.pem 2048 && openssl rsa -in trial_private.pem -pubout -out trial_public.pem
# LICENSE_TRIAL_PUBLIC_KEY=
# LICENSE_TRIAL_PRIVATE_KEY=

# --- OPTIONAL: PROGENTO (help chat, docs, technical KB) ---
# PROGENTO_API_URL=http://172.17.0.1:8001
# PROGENTO_COGENTO_KB_REPO_ID=cogento
# PROGENTO_HELP_CHAT_MODEL=phi
# PROGENTO_DOCS_KB_REPO_ID=
# PROGENTO_TECHNICAL_KB_REPO_ID=

# --- OPTIONAL: MULTI-TENANT STRIPE (encrypt tenant Stripe keys in DB) ---
# Required only if tenants will store Stripe keys. Without it, keys use a temp key (lost on restart).
# Must be a stable Fernet key: run ./generate-stripe-encryption-key.sh and add the printed line here.
# STRIPE_KEY_ENCRYPTION_KEY=

# --- OPTIONAL: CLOUDFLARE TURNSTILE ---
# TURNSTILE_SITE_KEY=
# TURNSTILE_SECRET_KEY=
